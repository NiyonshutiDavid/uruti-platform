# ─── Frontend (Vite) ────────────────────────────────────────────────
# Set this to your backend URL (no trailing slash).
# Local testing default:
VITE_API_URL=http://localhost:8010
# Optional dedicated chatbot backend URL (recommended for model isolation)
VITE_CHATBOT_API_URL=http://localhost:8020

# ─── Backend (FastAPI) ──────────────────────────────────────────────
# Database connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uruti_db

# JWT secret – change this in production!
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=https://uruti.rw,https://www.uruti.rw

# Optional AI integration keys (set only when needed)
HF_TOKEN=hf_xxx
HUGGINGFACE_TOKEN=hf_xxx
HUGGINGFACE_API_TOKEN=hf_xxx
HUGGINGFACEHUB_API_TOKEN=hf_xxx
GEMINI_KEY=

# GGUF chatbot (llama-cpp) settings
URUTI_BEST_MODEL_ID=uruti-qwen-gguf
URUTI_CHATBOT_REPO_ID=NiyonshutiDavid/uruti-qwen2_5-7b-instruct-q4_k_m-gguf
URUTI_CHATBOT_GGUF_FILENAME=qwen2_5-7b-instruct-q4_k_m.gguf
# Optional: use a local downloaded model file instead of repo download
URUTI_CHATBOT_LOCAL_GGUF_PATH=
URUTI_CHATBOT_CTX=4096
URUTI_CHATBOT_MAX_TOKENS=512
URUTI_CHATBOT_TEMPERATURE=0.2
# Core backend checks this URL to report dedicated chatbot service health in admin diagnostics.
CHATBOT_SERVICE_URL=http://127.0.0.1:8020

# Optional pitch coach model (HF transformers)
PITCH_COACH_MODEL_ID=
