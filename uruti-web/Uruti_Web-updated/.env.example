# ─── Frontend (Vite) ────────────────────────────────────────────────
# Set this to your hosted backend URL (no trailing slash).
# During development it defaults to http://localhost:8000
VITE_API_URL=https://api.uruti.rw

# ─── Backend (FastAPI) ──────────────────────────────────────────────
# Database connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uruti_db

# JWT secret – change this in production!
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=https://uruti.rw,https://www.uruti.rw
